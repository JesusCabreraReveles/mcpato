MCPATO_DB=./data/mcpato.sqlite
MCPATO_SYMBOL=BTCUSDT
MCPATO_INTERVAL=5m
MCPATO_INITIAL_CAPITAL=100.0

MCPATO_P_MUT=0.05
MCPATO_SIGMA_SMALL=0.02
MCPATO_SIGMA_MED=0.08
MCPATO_SIGMA_BIG=0.25
MCPATO_P_BIG=0.01
MCPATO_P_MED=0.09

MCPATO_SIGNAL_THRESHOLD=0.2
MCPATO_COMMISSION=0.001
MCPATO_SLIPPAGE=0.0002

MCPATO_SURVIVAL_RATE=0.0005

# --- Señales de acción (Fase 1) ---
# Nombre legible del instrumento que aparece en la tabla de señales.
MCPATO_INSTRUMENT_NAME=bitcoin
# Tiempo de vida (segundos) de una señal PENDING antes de expirar. 300 = 5 min (1 vela).
MCPATO_SIGNAL_TTL_SECS=300
# Umbral mínimo de valor de posición para considerarla "comprado" (LONG).
MCPATO_POSITION_EPSILON=0.000000001

# --- Notificaciones Telegram (Fase 2) ---
# Activa/desactiva el envío. Si es false, nunca notifica.
MCPATO_NOTIFY_ENABLED=true
# Token del bot que te da @BotFather (formato 123456789:ABC-...).
MCPATO_TELEGRAM_TOKEN=
# Tu chat_id numérico (ver README, sección "Notificaciones por Telegram").
MCPATO_TELEGRAM_CHAT_ID=
# Timeout (segundos) de cada llamada a la API de Telegram.
MCPATO_NOTIFY_TIMEOUT_SECS=10

# --- Dashboard web (Fase 3) ---
# Activa/desactiva el servidor HTTP del dashboard.
MCPATO_HTTP_ENABLED=true
# IP de escucha. 127.0.0.1 = solo local; 0.0.0.0 = accesible en la red.
MCPATO_HTTP_BIND=127.0.0.1
# Puerto del dashboard.
MCPATO_HTTP_PORT=8080
# Segundos sin vela nueva tras los cuales se marca la salud como "datos atrasados".
MCPATO_STALE_AFTER_SECS=900

MCPATO_MAX_GENERATIONS=
